{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/oura/main/json-schema/oura-publicrestmodeperiod.json",
  "title": "PublicRestModePeriod",
  "description": "Rest mode episode information.",
  "properties": {
    "id": {
      "type": "string",
